{
  "name": "supersplat-export-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:shared": "node ../scripts/build-shared.mjs",
    "build": "npm run build:shared && tsc",
    "dev": "npm run build:shared && tsx watch src/index.ts",
    "start": "node dist/index.js",
    "pretest": "npm run build:shared",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/multipart": "10.0.0",
    "@fastify/static": "9.1.3",
    "@playcanvas/splat-transform": "2.5.2",
    "fastify": "5.8.5",
    "playcanvas": "2.19.5",
    "webgpu": "0.4.0"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
