# S3 / DigitalOcean Spaces configuration for server-side Publish.
# Copy to .env.local (git-ignored) and fill in. All five S3_* below are
# required for the Publish option to appear in the client.

# Origin endpoint used for UPLOADS (not the CDN).
S3_ENDPOINT=https://fra1.digitaloceanspaces.com
S3_REGION=fra1
S3_BUCKET=my-space-name
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Base URL for the public links returned after publishing.
# Set this to your DigitalOcean CDN endpoint. If omitted, links fall back to
# ${S3_ENDPOINT}/${S3_BUCKET} (origin, path-style — works but not CDN-accelerated).
S3_PUBLIC_BASE_URL=https://my-space-name.fra1.cdn.digitaloceanspaces.com

# Optional: force path-style addressing (default false).
# S3_FORCE_PATH_STYLE=false
